{
  "name": "local-addon-zip-launcher",
  "productName": "Zip Launcher",
  "version": "0.2.1",
  "description": "Drop a WordPress theme or plugin zip anywhere in Local to create a site with it installed and activated.",
  "main": "lib/main.js",
  "renderer": "lib/renderer.js",
  "author": "Jeremy Pollock",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jpollock/local-addon-zip-launcher.git"
  },
  "localAddon": {
    "minimumLocalVersion": "6.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "node-stream-zip": "1.15.0"
  },
  "bundledDependencies": [
    "node-stream-zip"
  ],
  "devDependencies": {
    "@getflywheel/local": "^6.0.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "build": "npm run clean && npm run compile && npm run create-entry-points",
    "compile": "tsc -p .",
    "create-entry-points": "node scripts/create-entry-points.js",
    "clean": "rm -rf lib coverage",
    "watch": "tsc -p . --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "precommit": "npm run lint && npm run type-check && npm test",
    "validate-release": "node scripts/validate-release.js",
    "install-addon": "ln -sf \"$(pwd)\" \"$HOME/Library/Application Support/Local/addons/local-addon-zip-launcher\"",
    "prepare": "npm run build"
  }
}
